# ============================================================
# Albirru Online — Environment Variables
# Salin file ini menjadi .env.local lalu isi nilainya. JANGAN commit .env.local.
# ============================================================

# ── Supabase (wajib) ── Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# ── Supabase service-role (SERVER-ONLY) ──
# Dipakai HANYA oleh webhook pembayaran (mem-bypass RLS). JANGAN bocor ke client.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ── Dev preview (opsional, non-produksi) ──
# DEV_FAKE_AUTH=1 melewati login untuk preview portal.
# DEV_FAKE_ROLE=staf|admin untuk preview portal /staf & /admin.
# DEV_FAKE_AUTH=1
# DEV_FAKE_ROLE=admin

# ── Claude API (Tier 3 Intelligence — lib/ai/*) ──
ANTHROPIC_API_KEY=sk-ant-YOUR-KEY

# ── Midtrans (pembayaran nyata; default simulasi bila kosong) ──
MIDTRANS_SERVER_KEY=YOUR-MIDTRANS-SERVER-KEY
MIDTRANS_ENV=sandbox            # sandbox | production

# ── Resend (email transaksional; no-op bila kosong) ──
RESEND_API_KEY=re_YOUR-KEY
